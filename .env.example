# ── LLM provider config (PoC) ────────────────────────────────────────────────
# Which provider generates the chatbot's natural-language replies (NLG polish).
#   ollama    -> local LLM, no API key, best for the demo (DEFAULT)
#   template  -> pure templated text, no LLM at all (always works, zero deps)
#   openai    -> hosted OpenAI (enable later; needs OPENAI_API_KEY)
#   anthropic -> hosted Anthropic (enable later; needs ANTHROPIC_API_KEY)
LLM_PROVIDER=ollama

# ── Ollama (local, default) ──────────────────────────────────────────────────
# Install: https://ollama.com  then:  ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI (optional, enable later) ──────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (optional, enable later) ───────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# If the chosen LLM provider is unreachable, the app silently falls back to
# templated replies so the demo never breaks.
